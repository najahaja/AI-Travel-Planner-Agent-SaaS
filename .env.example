# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME="AI Travel Planner Agent"
APP_VERSION="1.0.0"
DEBUG=True
ENVIRONMENT=development

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./travel_planner.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/travel_planner

# ─── LLM Provider (choose one) ────────────────────────────────────────────────
GROQ_API_KEY=your-groq-api-key
LLM_MODEL=llama-3.1-8b-instant

# ─── RAG / ChromaDB ───────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─── External APIs ────────────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your-openweathermap-api-key
GOOGLE_PLACES_API_KEY=your-google-maps-platform-places-api-key

# ─── Super Admin Seed ─────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=superadmin@travelplanner.com
SUPER_ADMIN_PASSWORD=SuperAdmin@2025!

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_CHAT=20/minute
RATE_LIMIT_DEFAULT=100/minute

# ─── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
